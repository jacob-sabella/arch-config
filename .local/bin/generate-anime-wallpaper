#!/bin/bash
# Random wallpaper generator via stable-diffusion.cpp
# Single-pass at 1344x768 → upscayl 4x → crop to 7680x2160

SD_BIN="$HOME/AI/stable-diffusion.cpp/build/bin/sd"
MODELS_DIR="$HOME/AI/models"
WALLPAPER_DIR="$HOME/Pictures/Wallpapers"
TEMP_GEN="/tmp/wallpaper_gen.png"
TEMP_UPSCALED="/tmp/wallpaper_upscaled.png"
LAST_MODEL_CACHE="$HOME/.cache/last-sd-model"
MONITOR="HDMI-A-2"
TARGET_W=7680
TARGET_H=2160
UPSCAYL="/usr/share/upscayl/bin/upscayl-bin"
UPSCAYL_MODELS="/usr/share/upscayl/models"

# Use last selected model, or default to animagine
if [ -f "$LAST_MODEL_CACHE" ]; then
    SELECTED_MODEL=$(cat "$LAST_MODEL_CACHE")
    MODEL_PATH=$(find "$MODELS_DIR" -name "${SELECTED_MODEL}.safetensors" -type f | head -1)
fi
if [ -z "$MODEL_PATH" ] || [ ! -f "$MODEL_PATH" ]; then
    MODEL_PATH="$MODELS_DIR/sdxl/Juggernaut-XL_v9_RunDiffusionPhoto_v2.safetensors"
    SELECTED_MODEL="Juggernaut-XL_v9_RunDiffusionPhoto_v2"
fi

MODEL_LOWER="${SELECTED_MODEL,,}"

if [[ "$MODEL_LOWER" == *"xl"* ]] || [[ "$MODEL_LOWER" == *"juggernaut"* ]]; then
    GEN_W=1344; GEN_H=768
else
    GEN_W=768; GEN_H=448
fi

# Model-type-aware generation params
# Lightning/Turbo = distilled, needs very low steps + CFG
if [[ "$MODEL_LOWER" == *"lightning"* ]] || [[ "$MODEL_LOWER" == *"turbo"* ]] || [[ "$MODEL_LOWER" == *"lcm"* ]]; then
    STEPS=8
    CFG=2.0
    SAMPLER="euler"
    SCHEDULER="discrete"
else
    STEPS=80
    CFG=7.0
    SAMPLER="dpm++2m"
    SCHEDULER="karras"
fi

# Animagine/Illustrious want Danbooru quality tags
if [[ "$MODEL_LOWER" == *"animagine"* ]] || [[ "$MODEL_LOWER" == *"illustrious"* ]]; then
    QUALITY="masterpiece, best quality, very aesthetic, absurdres, highly detailed, intricate details, no humans, scenery"
    NEG="worst quality, low quality, lowres, text, watermark, signature, blurry, ugly, deformed, tiling, split screen, multiple panels, humans, person, character, bad composition"
else
    QUALITY="masterpiece, best quality, ultra detailed, highly detailed, 8k, sharp focus, professional photography, dramatic lighting, cinematic"
    NEG="worst quality, low quality, blurry, ugly, deformed, watermark, text, signature, tiling, split screen, multiple panels, bad composition, overexposed, underexposed, flat colors"
fi

PROMPTS=(
    "cherry blossom forest path, ancient stone lanterns lining the way, cascading pink petals in the wind, spring morning golden mist, god rays through towering trees, moss-covered stones, tranquil silence"
    "neon-drenched cyberpunk megacity at 3am, towering holographic ads reflected in rain-soaked streets, steam vents, crowds with umbrellas, flying vehicles, oppressive urban density, blade runner atmosphere"
    "chain of floating sky islands connected by ancient rope bridges, titanic waterfalls cascading through clouds, ruins of a lost civilization, glowing crystal spires, violet and gold sunset sky"
    "abyssal ocean floor, cathedral of bioluminescent coral, giant ancient stone ruins half-buried in sand, shafts of silver light from the surface, schools of glowing deep-sea creatures"
    "mountain village buried in snowfall, glowing paper lanterns strung over a frozen river, warm amber light from traditional wooden inns, pine trees heavy with snow, distant peak under moonlight"
    "vast red desert at dusk, towering ancient temple facades carved into canyon walls, a lone figure silhouette on a sand dune, crimson and violet sky, geometric sand patterns, archaeological dig site"
    "primordial enchanted forest, cathedral canopy of ancient oaks, giant bioluminescent mushrooms six meters tall, firefly clouds, moonbeams cutting through thick mist, fairy-ring clearing"
    "orbital megastructure, curved habitat ring against a gas giant, stars and nebula filling the sky, shuttle traffic, solar panels spanning kilometers, hard sci-fi detail"
    "mediterranean cliff town at magic hour, terracotta rooftops cascading to turquoise sea, bougainvillea, golden light on whitewashed walls, a dozen sailboats in the harbor below"
    "bamboo forest at dawn, perfect columns of green, morning fog low to the ground, shafts of warm light, mossy stone lanterns, a hidden wooden torii gate ahead"
    "caldera of an active stratovolcano, rivers of orange lava cutting through black rock, billowing ash clouds lit from below, eerie desolate beauty, heat shimmer"
    "subarctic tundra, aurora borealis in ribbons of green and violet across the sky, perfectly still frozen lake as a mirror, lone wolf at the treeline, deep cosmic silence"
    "massive dragon coiled around a moonlit mountain peak above the clouds, lightning crackling in the distance, scales of burnished copper, epic fantasy scale, painterly detail"
    "feudal japanese castle on a clifftop, cherry blossom trees in full bloom, samurai on patrol below, pink and gold dawn sky, mist-filled valley, swooping cranes"
    "sunken ancient city on the seafloor, marble columns draped in coral, stained glass cathedral windows intact, rays of turquoise light, whale swimming overhead through open roof"
)

PROMPT="${PROMPTS[$RANDOM % ${#PROMPTS[@]}]}"
FULL_PROMPT="${QUALITY}, ${PROMPT}, wide panoramic view, epic scale, cinematic framing"

echo "Model:    $SELECTED_MODEL"
echo "Steps:    $STEPS  CFG: $CFG  Sampler: $SAMPLER/$SCHEDULER"
echo "Prompt:   $PROMPT"
echo ""
notify-send "Wallpaper Generator" "Generating..." -t 2000

"$SD_BIN" \
    -m "$MODEL_PATH" \
    -p "$FULL_PROMPT" \
    -n "$NEG" \
    -o "$TEMP_GEN" \
    -W "$GEN_W" -H "$GEN_H" \
    --steps "$STEPS" \
    --cfg-scale "$CFG" \
    --sampling-method "$SAMPLER" \
    --scheduler "$SCHEDULER" \
    --rng cuda \
    --vae-tiling \
    -s -1

if [ $? -ne 0 ] || [ ! -f "$TEMP_GEN" ]; then
    echo "Generation failed."
    notify-send "Wallpaper Generator" "Generation failed" -t 3000
    exit 1
fi

echo "Upscaling 4x..."
notify-send "Wallpaper Generator" "Upscaling 4x..." -t 2000
"$UPSCAYL" -i "$TEMP_GEN" -o "$TEMP_UPSCALED" \
    -n digital-art-4x -m "$UPSCAYL_MODELS" -z 4 -f png 2>/dev/null

if [ ! -f "$TEMP_UPSCALED" ]; then
    cp "$TEMP_GEN" "$TEMP_UPSCALED"
fi
rm -f "$TEMP_GEN"

TIMESTAMP=$(date +%Y%m%d_%H%M%S)
DEST="$WALLPAPER_DIR/wallpaper_${TIMESTAMP}.png"
mkdir -p "$WALLPAPER_DIR"
convert "$TEMP_UPSCALED" \
    -resize ${TARGET_W}x${TARGET_H}^ \
    -gravity center \
    -extent ${TARGET_W}x${TARGET_H} \
    "$DEST"
rm -f "$TEMP_UPSCALED"

echo "Saved: $DEST"
awww img "$DEST" --outputs "$MONITOR" 2>/dev/null
echo "$DEST" > "$HOME/.cache/current-wallpaper"
notify-send "Wallpaper Ready" "$(basename "$DEST")" -t 3000
